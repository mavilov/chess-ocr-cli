{
  "name": "chess-ocr-cli",
  "version": "1.0.0",
  "description": "A CLI tool to convert chess game protocols from images to PGN format using AI vision",
  "main": "dist/index.js",
  "bin": {
    "chess-ocr-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "ts-node index.ts",
    "dev": "ts-node index.ts",
    "prettier:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prettier:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "keywords": [
    "chess",
    "ocr",
    "cli",
    "pgn",
    "ai",
    "vision"
  ],
  "author": "Maksim Avilov",
  "license": "ISC",
  "dependencies": {
    "@types/node": "^25.4.0",
    "commander": "^14.0.0",
    "dotenv": "^17.3.1",
    "openai": "^6.25.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/commander": "^2.12.5",
    "prettier": "^3.8.1"
  }
}
